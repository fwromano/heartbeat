#!/usr/bin/env bash
# ==========================================================================
# Heartbeat - TAK Server Manager for Teams
# ==========================================================================
# Main CLI tool for managing your FreeTAKServer deployment.
#
# Usage:
#   ./heartbeat <command> [args]
#
# Commands:
#   start                Start the TAK server
#   stop                 Stop the TAK server
#   restart              Restart the TAK server
#   status               Show server status
#   logs [-f]            View server logs (-f to follow)
#   package <name>       Generate a connection package for a team member
#   packages             List all generated packages
#   serve [port]         Serve packages over HTTP for phone download
#   info                 Show server connection info
#   update               Update FreeTAKServer
#   uninstall            Remove everything
#   help                 Show this help
# ==========================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/lib/common.sh"

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------
show_help() {
    banner
    echo -e "${BOLD}Usage:${NC} ./heartbeat <command> [args]"
    echo ""
    echo -e "${BOLD}Server:${NC}"
    echo "  start                Start the TAK server"
    echo "  stop                 Stop the TAK server"
    echo "  restart              Restart the TAK server"
    echo "  status               Show server status and port checks"
    echo "  listen               Live monitor -- follow connections and events"
    echo "  logs [-f]            View server logs (-f to follow)"
    echo ""
    echo -e "${BOLD}Team:${NC}"
    echo "  qr                   Show QR code to scan from iTAK/ATAK"
    echo "  tailscale            Set SERVER_IP to the Tailscale IP"
    echo "  package <name>       Generate a connection package for a member"
    echo "  packages             List all generated packages"
    echo "  serve [port]         HTTP-serve packages for phone download (default :9000)"
    echo ""
    echo -e "${BOLD}System:${NC}"
    echo "  info                 Show server connection details"
    echo "  update               Update FreeTAKServer to latest version"
    echo "  systemd              Install systemd service (native mode, requires sudo)"
    echo "  uninstall            Remove FreeTAKServer and optionally data"
    echo "  clean                Remove all generated artifacts (packages, certs, logs)"
    echo "  help                 Show this help"
    echo ""
    echo -e "${BOLD}Examples:${NC}"
    echo "  ./heartbeat start"
    echo "  ./heartbeat package \"Chief Smith\""
    echo "  ./heartbeat serve"
    echo "  ./heartbeat status"
    echo ""
}

# ---------------------------------------------------------------------------
# Info command
# ---------------------------------------------------------------------------
cmd_info() {
    load_config

    banner
    echo -e "${BOLD}Server Connection Info${NC}"
    echo -e "${DIM}----------------------------------${NC}"
    echo ""
    echo -e "  Team:        ${TEAM_NAME}"
    echo -e "  Server IP:   ${CYAN}${SERVER_IP}${NC}"
    echo -e "  CoT Port:    ${CYAN}${COT_PORT}${NC} (TCP)"
    echo -e "  SSL Port:    ${SSL_COT_PORT}"
    echo -e "  API Port:    ${API_PORT}"
    echo -e "  Mode:        ${DEPLOY_MODE}"
    echo ""
    echo -e "  ${BOLD}Manual connection in iTAK/ATAK:${NC}"
    echo -e "  1. Open Settings > Network Preferences > Servers"
    echo -e "  2. Add new server:"
    echo -e "     Address:  ${CYAN}${SERVER_IP}${NC}"
    echo -e "     Port:     ${CYAN}${COT_PORT}${NC}"
    echo -e "     Protocol: TCP"
    echo ""

}

# ---------------------------------------------------------------------------
# Update command
# ---------------------------------------------------------------------------
cmd_update() {
    source "${LIB_DIR}/server.sh"
    _load_backend
    backend_update
}

# ---------------------------------------------------------------------------
# Command prefix matching
# Allows short abbreviations: "st" -> "start", "sta" -> "status" etc.
# ---------------------------------------------------------------------------
COMMANDS=(start stop restart status listen logs qr tailscale package packages serve clean info update systemd uninstall help)

resolve_cmd() {
    local input="$1"
    # Exact match first (including aliases)
    case "$input" in
        log) echo "logs"; return ;;
        pkg) echo "package"; return ;;
        pkgs|list) echo "packages"; return ;;
        upgrade) echo "update"; return ;;
        remove) echo "uninstall"; return ;;
        --help|-h) echo "help"; return ;;
    esac
    # Prefix match
    local matches=()
    for c in "${COMMANDS[@]}"; do
        if [[ "$c" == "$input"* ]]; then
            matches+=("$c")
        fi
    done
    if [[ ${#matches[@]} -eq 1 ]]; then
        echo "${matches[0]}"
    elif [[ ${#matches[@]} -gt 1 ]]; then
        log_error "Ambiguous command '${input}' matches: ${matches[*]}"
        exit 1
    else
        echo ""
    fi
}

# ---------------------------------------------------------------------------
# Route commands
# ---------------------------------------------------------------------------
raw_cmd="${1:-help}"
shift || true

cmd=$(resolve_cmd "$raw_cmd")
if [[ -z "$cmd" ]]; then
    log_error "Unknown command: ${raw_cmd}"
    echo ""
    show_help
    exit 1
fi

case "$cmd" in
    start)
        source "${LIB_DIR}/server.sh"
        server_start
        ;;
    stop)
        source "${LIB_DIR}/server.sh"
        server_stop
        ;;
    restart)
        source "${LIB_DIR}/server.sh"
        server_restart
        ;;
    status)
        source "${LIB_DIR}/server.sh"
        server_status
        ;;
    listen)
        source "${LIB_DIR}/server.sh"
        server_listen
        ;;
    logs)
        source "${LIB_DIR}/server.sh"
        server_logs "${1:-}"
        ;;
    qr)
        source "${LIB_DIR}/qr.sh"
        show_qr
        ;;
    tailscale)
        load_config
        ts_ip=$(detect_tailscale_ip || true)
        if [[ -z "$ts_ip" ]]; then
            log_error "Tailscale IP not found. Is Tailscale running?"
            exit 1
        fi
        set_config "TAILSCALE_MODE" "true"
        set_config "SERVER_IP" "$ts_ip"
        log_ok "SERVER_IP set to ${ts_ip}"
        log_info "Regenerate packages to update the server IP."
        ;;
    package)
        if [[ $# -lt 1 ]]; then
            log_error "Usage: ./heartbeat package \"Member Name\""
            exit 1
        fi
        source "${LIB_DIR}/package.sh"
        generate_package "$1"
        ;;
    packages)
        source "${LIB_DIR}/package.sh"
        list_packages
        ;;
    serve)
        source "${LIB_DIR}/package.sh"
        serve_packages "${1:-9000}"
        ;;
    clean)
        source "${LIB_DIR}/server.sh"
        server_stop 2>/dev/null || true
        load_config
        log_step "Cleaning all generated artifacts"
        rm -f "${PACKAGES_DIR}"/*.zip "${PACKAGES_DIR}"/*.png "${PACKAGES_DIR}"/index.html 2>/dev/null
        rm -f "${DATA_DIR}"/*.log "${DATA_DIR}"/*.pid 2>/dev/null
        rm -f "${HEARTBEAT_DIR}/.config.nodes.json" "${HEARTBEAT_DIR}/.config.runtime.json" \
              "${HEARTBEAT_DIR}/package.json" 2>/dev/null
        rm -rf "${HEARTBEAT_DIR}/JsonDB" 2>/dev/null
        if has_docker; then
            compose_cmd=$(get_compose_cmd)
            if [[ -n "$compose_cmd" ]]; then
                (cd "$DOCKER_DIR" && $compose_cmd down -v 2>/dev/null) || true
            fi
        fi
        sudo rm -rf "${DOCKER_DIR}/certs" "${DOCKER_DIR}/data" "${DOCKER_DIR}/logs" 2>/dev/null || true
        ensure_dir "${DOCKER_DIR}/data"
        ensure_dir "${DOCKER_DIR}/logs"
        ensure_dir "${DOCKER_DIR}/certs"
        log_ok "Clean. Run ./setup.sh to start fresh."
        ;;
    info)
        cmd_info
        ;;
    update)
        cmd_update
        ;;
    systemd)
        source "${LIB_DIR}/install.sh"
        install_systemd_service
        ;;
    uninstall)
        source "${LIB_DIR}/server.sh"
        _load_backend
        backend_uninstall
        ;;
    help)
        show_help
        ;;
esac
