        <mxCell id="se_export_gcm" parent="1" edge="1" source="d_exports" target="sb_export_gcm" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=oval;endFill=1;strokeColor=#94a3b8;fontColor=#cbd5e1;fontSize=9;dashed=1;" value="has-part">
