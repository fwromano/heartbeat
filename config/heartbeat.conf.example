# ==========================================================================
# Heartbeat - TAK Server Configuration
# ==========================================================================
# Copy this to heartbeat.conf and edit, or run ./setup.sh to generate.

# Organization / team name (shown in connection packages)
TEAM_NAME="My Volunteer FD"

# Server IP that clients connect to (auto-detected during setup)
SERVER_IP=""

# Deployment mode: "docker" or "native"
DEPLOY_MODE="docker"
TAILSCALE_MODE="false"

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
TAK_BACKEND="freetak"   # Options: freetak (default), opentak

# OpenTAK-specific (only used when TAK_BACKEND=opentak)
WEBTAK_PORT=8443        # WebTAK HTTPS interface
OTS_RECORDER_TRANSPORT="ssl"      # Recorder transport: ssl (default), tcp, or rmq
OTS_RECORDER_CERT_USER="administrator"  # Used only when OTS_RECORDER_TRANSPORT=ssl

# ---------------------------------------------------------------------------
# Ports
# ---------------------------------------------------------------------------
COT_PORT=8087            # Main Cursor-on-Target streaming (TCP). OpenTAK defaults to 8088.
SSL_COT_PORT=8089        # SSL CoT port
API_PORT=8443            # WebTAK / OpenTAK API
DATAPACKAGE_PORT=8443    # Data package service

# ---------------------------------------------------------------------------
# Auth settings (used by OpenTAK and FreeTAK workflows)
# ---------------------------------------------------------------------------
FTS_SECRET_KEY=""        # Generated during setup
FTS_CONNECTION_MSG="Welcome to Heartbeat TAK"
FTS_USERNAME="admin"     # Default TAK/WebTAK username (set during setup)
FTS_PASSWORD=""          # Generated during setup — do not commit

# ---------------------------------------------------------------------------
# Paths (relative to heartbeat repo root)
# ---------------------------------------------------------------------------
FTS_DATA_DIR=""          # Set during setup
